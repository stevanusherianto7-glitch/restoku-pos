APP_NAME=Restoku
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost
# Base URL untuk QR buku menu tamu. Kosongkan di produksi (pakai domain otomatis).
# Di dev, isi URL yang bisa dijangkau HP: http://<IP-LAN>:8000 atau ngrok (localhost tidak reachable dari HP).
MENU_BASE_URL=


APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# Session & cache: untuk skala 5.000+ tenant wajib REDIS (file/database tidak scale
# horizontal & jadi bottleneck write per-request). Pastikan Redis berjalan.
SESSION_DRIVER=redis
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_PATH=/
SESSION_DOMAIN=null

# Redis alerting threshold (audit Pilar 5 #3) — notifikasi bila lewat batas
REDIS_ALERT_MEM_PERCENT=80
REDIS_ALERT_CONN_PERCENT=80

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Cloudinary (foto menu) — WAJIB di produksi untuk skala 500k outlet.
# Format resmi: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Tanpa ini: upload foto menu fallback ke null (frontend pakai placeholder).
CLOUDINARY_URL=

# ── Fase 2: Schema-per-tenant (Postgres) ──────────────────────────────────────
# Shared DB (tenants, outlet pemeta slug->schema)
DB_CONNECTION_SYS=pgsql
DB_HOST_SYS=127.0.0.1
DB_PORT_SYS=5432
DB_DATABASE_SYS=restoku_sys
DB_USERNAME_SYS=forge
DB_PASSWORD_SYS=
# Read replica (beban baca: CustomerView / public menu)
DB_HOST_READ=127.0.0.1
DB_PORT_READ=5432
DB_USERNAME_READ=forge
DB_PASSWORD_READ=
# Aktifkan sharding (false di sqlite/test → fallback shared schema + TenantScope)
DB_SHARDING_ENABLED=true

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Google OAuth (Masuk dengan Google — login/register owner)
# Dari Google Cloud Console: APIs & Services → Credentials → OAuth 2.0 Client ID (Web application)
# Authorized redirect URI = {APP_URL}/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Untuk dev lokal: http://localhost:8000/oauth/google/callback
# Untuk produksi VPS: https://DOMAIN_ANDA/oauth/google/callback (samakan dengan Google Cloud Console)
GOOGLE_REDIRECT_URI="http://localhost:8000/oauth/google/callback"

VITE_APP_NAME="${APP_NAME}"

# Laravel 13 AI SDK Configurations
# Provider gratis no-card: 'groq' (llama-3.3-70b) atau 'deepseek' (deepseek-chat).
# Untuk dev tanpa billing, set AI_DEFAULT_PROVIDER=groq + isi GROQ_API_KEY.
AI_DEFAULT_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
